@model IEnumerable<PPOO2.Models.ViewModels.ListPost1>

@{
    ViewData["Title"] = "Listado";
    int page = ViewBag.Page ?? 1;
    int pageSize = ViewBag.PageSize ?? 5;
    int totalRegistros = ViewBag.TotalRegistros ?? 0;
    int totalPaginas = ViewBag.TotalPaginas ?? 0;
}

<h1>Lista de Recomendaciones (incompleta)</h1>

<p>
    <a class="btn btn-primary" asp-action="Create">Crear Nuevo</a>
</p>

<form method="get" action="@Url.Action("Index", "Post1")" id="filtersForm">
    <div class="row g-2">
        <div class="col-md-3">
            <label class="form-label mb-1">Titulo</label>
            <input class="form-control" type="text" placeholder="Ingrese el Nombre o Titulo a buscar"
                   name="titulo" value="@ViewBag.Titulo" />
        </div>
        <div class="col-md-3">
            <label class="form-label mb-1">Artista</label>
            <input class="form-control" type="text" placeholder="Ingrese el Artista a buscar"
                   name="artista" value="@ViewBag.Artista" />
        </div>
        <div class="col-md-3">
            <label class="form-label mb-1">Género</label>
            <input class="form-control" type="text" placeholder="Ingrese el Género a buscar"
                   name="genero" value="@ViewBag.Genero" />
        </div>
        <div class="col-md-auto">
            <label class="form-label text-white mb-1">.</label>
            <button type="submit" class="btn btn-success form-control">Filtrar</button>
        </div>
        <div class="col-md-auto">
            <label class="form-label text-white mb-1">.</label>
            <button type="button" class="btn btn-secondary form-control" id="btnClear">Limpiar</button>
        </div>
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.title)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.artist)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.genre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.release_date)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.uploader)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.upload_date)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.approbation)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.title)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.artist)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.genre)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.release_date)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.uploader)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.upload_date)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.approbation)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>

@if (totalRegistros > 0)
{
    <nav aria-label="Paginación">
        <ul class="pagination">
            @* Anterior *@
            @if (page > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="@Url.Action("Index", new {
                        titulo = ViewBag.Titulo,
                        artista = ViewBag.Artista,
                        genero = ViewBag.Genero,
                        page = page - 1,
                        pageSize = pageSize
                    })">◁</a>
                </li>
            }
            <li class="page-item disabled">
                <span class="page-link">Página @(page) de @(totalPaginas)</span>
            </li>
            @* Siguiente *@
            @if (page < totalPaginas)
            {
                <li class="page-item">
                    <a class="page-link" href="@Url.Action("Index", new {
                        titulo = ViewBag.Titulo,
                        artista = ViewBag.Artista,
                        genero = ViewBag.Genero,
                        page = page + 1,
                        pageSize = pageSize
                    })">▷</a>
                </li>
            }
        </ul>
    </nav>
}

@section Scripts {
    <script>
        (function(){
            var BtnClear = document.getElementById('btnClear');
            var form = document.getElementById('filtersForm');

            BtnClear.addEventListener('click', function(){
                if(!form) return;

                var elements = form.querySelectorAll('input, select')
                elements.forEach(function(el){
                    if (el.tagName.toLowerCase() === 'select'){
                        el.selectedIndex = 0;
                    } else {
                        el.value = '';
                    }
                });

                var pageSize = form.querySelector('input[name="pageSize"]');
                if(pageSize) pageSize.value = 5;

                form.submit();
            });
        })();
    </script>
}

